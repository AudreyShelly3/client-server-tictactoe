<div class="game">

        <div class="grid">
            <div>
                <div>
                    <div class="bnr hide">Winner: Player 1 (Nkosi)</div>

                    @if (State == "Playing")
                    {
                        if (PlayerPosition == 2)
                        { 
                            <div class="bnr-2">
                                <p>Player 1: @GetValueByUserId(CurrentOpponent_UserId, "Username") [X]</p>
                                <p>Player 2: @CurrentUsername (You) [O]</p>
                            </div>
                        }
                        else if (PlayerPosition == 1)
                        {
                            <div class="bnr-2">
                                <p>Player 1: @CurrentUsername (You) [X]</p>
                                <p>Player 2: @GetValueByUserId(CurrentOpponent_UserId, "Username") [O]</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="bnr-2">
                            <p>Player 1: @CurrentUsername (You)</p>
                            <p>Player 2: ...</p>
                        </div>
                    }
                    
                </div>  
                <div class="grid-ch-01">
                     <div class="box" id="a1" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "a1"))'>@IsActive("a1")</div>
                     <div class="box" id="a2" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "a2"))'>@IsActive("a2")</div>
                     <div class="box" id="a3" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "a3"))'>@IsActive("a3")</div>
                     <div class="box" id="b1" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "b1"))'>@IsActive("b1")</div>
                     <div class="box" id="b2" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "b2"))'>@IsActive("b2")</div>
                     <div class="box" id="b3" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "b3"))'>@IsActive("b3")</div>
                     <div class="box" id="c1" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "c1"))'>@IsActive("c1")</div>
                     <div class="box" id="c2" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "c2"))'>@IsActive("c2")</div>
                     <div class="box" id="c3" @onclick='(() => MakeMove(GetChar(), CurrentUserId, "c3"))'>@IsActive("c3")</div>
                </div>

                <br />

                <button @onclick="CancelGame">Cancel Game</button>
            </div>
        </div>
        <div class="chat">
             
            @code
            {
                public List<string> Threads = new List<string>();

                public string InputText { get; set; }

                public async Task Send() {

                    if (InputText == "!join")
                    {
                        ShowPlayerPick();
                    }
                    else if (InputText == "!scores")
                    {
                        ListScores();
                    }
                    else
                    {
                        if (!String.IsNullOrEmpty(InputText))
                        {  
                            hubConnection.SendAsync("SendString", $"SEND_MESSAGE:{CurrentUsername}:{InputText}"); 
                            InputText = "";
                            this.InvokeAsync(() => StateHasChanged());
                        } 
                    }

                }

                public  List<string> ThreadsR()
                {
                    List<string> R = Threads;
                    R.Reverse();
                    return R;
                }
            }
              
            <div class="threads">
                 
                @foreach (string s in ThreadsR())
                {
                    <p>@s</p>
                }

            </div>
             
            <div class="s-box">
                <input @bind-value="InputText" placeholder="Enter text here..."/>
                <button @onclick="Send">Send</button>
            </div>
        </div>


    </div>


    <div class="state">State: @State</div>



 