@code {

    static string GetUserScoresString(List<UserScore> userScores)
    {
        StringBuilder sb = new StringBuilder();

        foreach (UserScore userScore in userScores)
        {
            sb.AppendLine($"Username: {userScore.ID}, Score: {userScore.Score}       "); 
            sb.AppendLine($"       ");
            sb.AppendLine($"       ");
        }

        return sb.ToString();
    }


