@code
{
    public bool ShowMessage_ = false;
    public string Message_ { get; set; }
    public void ShowMessage (string Message)
    {
        this.InvokeAsync(() => StateHasChanged());
        if (!String.IsNullOrEmpty(Message))
        {
            ShowMessage_ = true;
            Message_ = Message;
            this.InvokeAsync(() => StateHasChanged());
        }
    }

    int Update = 0;
    int Update__ = 0;

    public void CloseMessage()
    {

        if (WinMade)
        { 
            if (Update == 0)
            {
                double oldWinValue = Convert.ToDouble(GetValueByUserId(WinnerId, "Wins"));
                oldWinValue = oldWinValue + 1;

                ModifyUserData(WinnerId, "Wins", $"{oldWinValue}");


                double oldLossValue = Convert.ToDouble(GetValueByUserId(LoserId, "Losses"));
                oldLossValue = oldLossValue + 1;

                ModifyUserData(LoserId, "Losses", $"{oldLossValue}");

                Update++;
            }
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }

        if (drawmade)
        {
            if (Update__ == 0)
            {   
                double a = Convert.ToDouble(GetValueByUserId(CurrentUserId, "Draws"));
                a = a + 1; 
                ModifyUserData(CurrentUserId, "Draws", $"{a}"); 
                Update__++; 
            }

            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }

        
        ShowMessage_ = false;
        Message_ = "";
        this.InvokeAsync(() => StateHasChanged());
        
        
    }
}

@if (ShowMessage_)
