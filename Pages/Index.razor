@code 
{

    bool WinMade = false;
     
    public bool playlock = false;

    public class moves
    {
        public string UserId { get; set; }
        public string Move { get; set; }
        public string Char { get; set; }
    }

    public List<moves> GameMoves = new List<moves>();

    public async Task MakeMove (string char_, string UserId, string Move)
    {
        if (State == "Playing")
        {
            Task.Run(() =>
            {
                hubConnection.SendAsync("SendString", $"MOVE:{char_}:{UserId}:{Move}");
            });
        }
       
    }

    public string IsActive (string Move)
    {
        string i = "";

        foreach (moves m in GameMoves)
        {
            if (m.Move.ToLower() == Move.ToLower())
            {
                i = m.Char;
            }
        }

        return i;
    }
 

    public bool CheckWinningMoves(string userId)
    {
        List<string> playerMoves = new List<string>();

        foreach (moves move in GameMoves)
        {
            if (move.UserId == userId)
            {
                playerMoves.Add(move.Move);
            }
        }

        Console.WriteLine($"Moves made by player {userId}:");
        foreach (string move in playerMoves)
        {
            Console.WriteLine(move);
        }

        /* Winning combinations
         * a1 a2 a3
         * b1 b2 b3
         * c1 c2 c3
         * c1 b2 a3
         * a1 b2 c3
         * a1 b1 c1
         * a3 b3 c3
         */

        bool hasWinningMoves = false;

        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a1") && playerMoves.Contains("a2") && playerMoves.Contains("a3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("b1") && playerMoves.Contains("b2") && playerMoves.Contains("b3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("c1") && playerMoves.Contains("c2") && playerMoves.Contains("c3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("c1") && playerMoves.Contains("b2") && playerMoves.Contains("a3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a1") && playerMoves.Contains("b2") && playerMoves.Contains("c3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a3") && playerMoves.Contains("b3") && playerMoves.Contains("c3");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a2") && playerMoves.Contains("b2") && playerMoves.Contains("c2");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a1") && playerMoves.Contains("b1") && playerMoves.Contains("c1");
        if (!hasWinningMoves) hasWinningMoves = playerMoves.Contains("a3") && playerMoves.Contains("b3") && playerMoves.Contains("c3");

        return hasWinningMoves;
    }
}








@code {


    class UserScore
    {
        public string ID { get; }
        public int Score { get; }

        public UserScore(string id, int score)
        {
            ID = id;
            Score = score;
        }  
    }

    List<UserScore> GetAllUserScores()
    {
        List<UserScore> userScores = new List<UserScore>();

        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string selectQuery = "SELECT Username, (CAST(Wins AS INT) - CAST(Losses AS INT)) AS Score FROM Users ORDER BY Score DESC";

            using (var command = new SQLiteCommand(selectQuery, connection))
            {
                using (var reader = command.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        string username = reader.GetString(0);
                        int score = reader.GetInt32(1);

                        UserScore userScore = new UserScore(username, score);
                        userScores.Add(userScore);
                    }
                }
            }
        }

        return userScores.OrderByDescending(x => x.Score).ToList();
    }
    public void CreateNewUser(string id, string username, string password, string wins, string losses, string draws)
    {
        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string insertQuery = "INSERT INTO Users (ID, Username, Password, Wins, Losses, Draws) VALUES (@ID, @Username, @Password, @Wins, @Losses, @Draws)";
            using (var command = new SQLiteCommand(insertQuery, connection))
            {
                command.Parameters.AddWithValue("@ID", id);
                command.Parameters.AddWithValue("@Username", username);
                command.Parameters.AddWithValue("@Password", password);
                command.Parameters.AddWithValue("@Wins", wins);
                command.Parameters.AddWithValue("@Losses", losses);
                command.Parameters.AddWithValue("@Draws", draws); 
                command.ExecuteNonQuery();
            }
        }
    }

      
    public void ModifyUserData(string userId, string columnName, string newValue)
    {
        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string updateQuery = $"UPDATE Users SET [{columnName}] = @NewValue WHERE ID = @UserId";
            using (var command = new SQLiteCommand(updateQuery, connection))
            {
                command.Parameters.AddWithValue("@NewValue", newValue);
                command.Parameters.AddWithValue("@UserId", userId);
                command.ExecuteNonQuery();
            }
        }
    }

    public bool AuthenticateUser(string username, string password)
    {
        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string selectQuery = "SELECT COUNT(*) FROM Users WHERE Username = @Username AND Password = @Password";
            using (var command = new SQLiteCommand(selectQuery, connection))
            {
                command.Parameters.AddWithValue("@Username", username);
                command.Parameters.AddWithValue("@Password", password);

                int result = Convert.ToInt32(command.ExecuteScalar());
                return result > 0;
            }
        }
    }

    public string GetValueByUserId(string userId, string columnName)
    {
        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string selectQuery = $"SELECT {columnName} FROM Users WHERE ID = @UserId";
            using (var command = new SQLiteCommand(selectQuery, connection))
            {
                command.Parameters.AddWithValue("@UserId", userId);

                var result = command.ExecuteScalar();
                if (result != null)
                {
                    return result.ToString();
                }
            }
        }

        return null;
    }


    public string GetUserIdByUsernameAndPassword(string username, string password)
    {
        using (var connection = Sql_dataService.GetDbConnection())
        {
            connection.Open();

            string selectQuery = "SELECT ID FROM Users WHERE Username = @Username AND Password = @Password";
            using (var command = new SQLiteCommand(selectQuery, connection))
            {
                command.Parameters.AddWithValue("@Username", username);
                command.Parameters.AddWithValue("@Password", password);

                var result = command.ExecuteScalar();
                if (result != null)
                {
                    return result.ToString();
                }
            }
        }

        return null;
    }

}

