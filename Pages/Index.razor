    public void ShowLoginDialog()
    {
        CloseMessage();
        CloseSignUpDialog();
        ShowLoginDialog_ = true;
        this.InvokeAsync(() => StateHasChanged());
    }  

    public void CloseLoginDialog()
    {
        ShowLoginDialog_ = false;
        this.InvokeAsync(() => StateHasChanged());
    }

    public void AuthenticateUser()
    {

        if (AuthenticateUser(LoginDialog_Username, LoginDialog_Password))
        {
            State = "Chatting";
            CurrentUserId = GetUserIdByUsernameAndPassword(LoginDialog_Username, LoginDialog_Password);
            CurrentUsername = LoginDialog_Username;
            CloseLoginDialog();
            CloseSignUpDialog();
            CloseMessage();
            //ShowPlayerPick();
        }
         else
         { 
            ShowMessage("Error: Wrong Username/Password!");
         }
         LoginDialog_Username = "";
         LoginDialog_Password = "";
         this.InvokeAsync(() => StateHasChanged());
       
    }
}

   
