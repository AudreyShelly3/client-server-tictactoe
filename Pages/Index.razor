@code 
{
    public HubConnection hubConnection; 
}

@code
{
    protected async override Task OnInitializedAsync()
    {   
        if (WhoseOnline.Count() > 0)
        {
            WhoseOnline.Clear();
        }

        CurrentUserId = "";
        CurrentUsername = ""; 
        State = "Login";

        if (CurrentUserId == "" || CurrentUsername == "" || CurrentUserId == null || CurrentUsername == null)
        { 
            ShowLoginDialog();
        }   

        this.InvokeAsync(() => StateHasChanged());

        hubConnection = new HubConnectionBuilder().WithUrl(NavigationManager.ToAbsoluteUri("/chathub")).WithAutomaticReconnect().Build();

        if (hubConnection is not null)
        {
            try
            {
                hubConnection.On<string>("ReceiveString", async (Msg) =>
                {
                    if (Msg.Split(':')[0] == "WHO_IS_ONLINE")
                    {
                        if (Msg.Split(':')[1] != CurrentUserId)
                        {
                            await Task.Run(() => { hubConnection.SendAsync("SendString", $"IAM_ONLINE:{CurrentUserId}:{CurrentUsername}"); }); 
                        } 
                        this.InvokeAsync(() => StateHasChanged());
                    } 
                    else if (Msg.Split(':')[0] == "IAM_ONLINE")
                    {
                        if (Msg.Split(':')[1] != CurrentUserId)
                        {
                            if (!String.IsNullOrEmpty(Msg.Split(':')[1]) && !String.IsNullOrEmpty(Msg.Split(':')[2]))
                            {
                                WhoseOnline.Add(new User_ { Id = Msg.Split(':')[1], Username = Msg.Split(':')[2] });
                                this.InvokeAsync(() => StateHasChanged());
                            } 
                        }
                    }
                    else if (Msg.Split(':')[0] == "LETSPLAY")
                    {
                        if (Msg.Split(':')[1] == CurrentUserId && State != "Playing")
                        {
                            State = "Playing";
                            CurrentOpponent_UserId = Msg.Split(':')[2];
                            CloseLoginDialog();
                            CloseMessage();
                            CloseSignUpDialog();
                            ClosePlayerPick();
                            PlayerPosition = 2;
                            await Task.Run(() => { hubConnection.SendAsync("SendString", $"ACCEPT_PLAY_REQUEST:{CurrentUserId}:{Msg.Split(':')[2]}"); });
                            this.InvokeAsync(() => StateHasChanged());
                        }
                        else
                        {
                            await Task.Run(() => { hubConnection.SendAsync("SendString", $"IM_BUSY:{CurrentUsername}:{Msg.Split(':')[2]}"); });
                            this.InvokeAsync(() => StateHasChanged());
                        }
                    }
                    else if (Msg.Split(':')[0] == "IM_BUSY" && Msg.Split(':')[2] == CurrentUserId)
                    {
                        ShowMessage($"{Msg.Split(':')[1]} is currently playing!");
                    }
                    else if (Msg.Split(':')[0] == "ACCEPT_PLAY_REQUEST" && Msg.Split(':')[2] == CurrentUserId)
                    {
                        if (true)
                        { 
                            State = "Playing";
                            PlayerPosition = 1;
                            CloseLoginDialog();
                            CloseMessage();
                            CloseSignUpDialog();
                            ClosePlayerPick();
                            CurrentOpponent_UserId = Msg.Split(':')[1];
                            //
                            this.InvokeAsync(() => StateHasChanged());
                        }
                        else
                        {

                        }
                    }
                    else if (Msg.Split(':')[0] == "SEND_MESSAGE")
                    {
                        Threads.Add($"{Msg.Split(':')[1]}: {Msg.Split(':')[2]}");
                        this.InvokeAsync(() => StateHasChanged());
                    }  

                    else if (Msg.Split(':')[0] == "MOVE")
                    {
                        bool invalidmove = false;
                        if (CurrentOpponent_UserId == Msg.Split(':')[2] || CurrentUserId == Msg.Split(':')[2]) 
                        {
                            if (GameMoves.Any(x => x.Move == Msg.Split(':')[3]))
                            {
                                invalidmove = true;
                            }
                            else {
                                GameMoves.Add (
                                   new moves {
                                            UserId = Msg.Split(':')[2],
                                            Move = Msg.Split(':')[3],
                                            Char = Msg.Split(':')[1]
                                        }
                                ); 

                                playlock = false;
                            }

                        }

                        if (!invalidmove)
                        {
                            if (CurrentOpponent_UserId == Msg.Split(':')[2])
                            {
                                ShowMessage("Your Turn!");
                                playlock = false;
                            }
                            else if (CurrentUserId == Msg.Split(':')[2])
                            {
                                playlock = true;
                            }

                            if (GameMoves.Count >= 9 && !CheckWinningMoves(CurrentUserId) && !CheckWinningMoves(CurrentOpponent_UserId))
                            { 
                                ShowMessage($"You Drew!");
                                drawmade = true;
                            }

                            if (CheckWinningMoves(CurrentUserId))
                            {
                                WinnerId = CurrentUserId;
                                LoserId = CurrentOpponent_UserId;
                                 
                                ShowMessage($"You Win!");
                                WinMade = true; 
                                 
                            } 


                            if (CheckWinningMoves(CurrentOpponent_UserId))
                            { 
                                ShowMessage($"{GetValueByUserId(CurrentOpponent_UserId, "Username")} Wins!");
                                WinMade = true;
                            }

                            this.InvokeAsync(() => StateHasChanged());
                        }

                           
                        } 

                    });
                }
                catch
                {

                }
        }
       
        await hubConnection.StartAsync();

        if (hubConnection.State == HubConnectionState.Connected)
        {
           await Task.Run(() => { FindPlayers(); });
        }
        else
        {
            ShowMessage("SignalR Error");
        }

       
         
    }
}



 
